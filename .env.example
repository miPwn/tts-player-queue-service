# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=tts_playback_queue

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_SIZE=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080

# PulseAudio Configuration
PULSEAUDIO_SINK=

# Logging (0=trace, 1=debug, 2=info, 3=warn, 4=error)
LOG_LEVEL=2
